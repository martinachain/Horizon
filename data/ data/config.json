                 
  {                                                                                 
    "version": "1.0",
    "ai": {
      "provider": "anthropic",                                                      
      "model": "claude-opus-4-5",
      "api_key_env": "ANTHROPIC_API_KEY",                                           
      "temperature": 0.3,
      "max_tokens": 4096,                                                           
      "throttle_sec": 0
    },                                                                              
    "email": {    
      "enabled": false                                                              
    },            
    "sources": {
      "hackernews": {
        "enabled": true,
        "fetch_top_stories": 20,
        "min_score": 100                                                            
      },
      "rss": [                                                                      
        {                                                                           
          "name": "CoinDesk",
          "url": "https://www.coindesk.com/arc/outboundfeeds/rss/",                 
          "enabled": true,                                                          
          "category": "crypto"                                                      
        },                                                                          
        {                                                                           
          "name": "Decrypt",
          "url": "https://decrypt.co/feed",
          "enabled": true,                                                          
          "category": "crypto"
        },                                                                          
        {         
          "name": "The Block",
          "url": "https://www.theblock.co/rss.xml",
          "enabled": true,                                                          
          "category": "crypto"
        }                                                                           
      ],          
      "reddit": {
        "enabled": true,
        "subreddits": [
          {                                                                         
            "subreddit": "CryptoCurrency",
            "enabled": true,                                                        
            "sort": "hot",
            "time_filter": "day",                                                   
            "fetch_limit": 15,
            "min_score": 100                                                        
          },      
          {                                                                         
            "subreddit": "defi",
            "enabled": true,
            "sort": "hot",
            "time_filter": "day",                                                   
            "fetch_limit": 10,
            "min_score": 50                                                         
          }       
        ],
        "users": [],
        "fetch_comments": 3                                                         
      },
      "twitter": {                                                                  
        "enabled": false
      },
      "github": []
    },                                                                              
    "filtering": {
      "ai_score_threshold": 6.0,                                                    
      "time_window_hours": 24
    },
    "webhook": {                                                                    
      "enabled": false
    }                                                                               
  } 
